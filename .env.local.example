# Sanity CMS Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=xb0i0wq8
NEXT_PUBLIC_SANITY_DATASET=production
MONGODB_URI=mongodb+srv://your_user:your_password@cluster.mongodb.net/?appName=Cluster0
# ── Site / SEO Configuration ──────────────────────────────────────────────────
# Absolute base URL for the deployed site. Used for canonical URLs, Open Graph
# URLs, JSON-LD `@id` values, the sitemap, and robots.txt.
# No trailing slash (one is stripped defensively, but cleaner to omit).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Display name used in titles, OG siteName, Organization schema.
NEXT_PUBLIC_SITE_NAME=Sage Narrative

# Fallback description for pages that don't provide their own.
NEXT_PUBLIC_SITE_DESCRIPTION=Thoughtful stories, tech blogs, and insights for the discerning reader.

# Default Open Graph / Twitter card image. Either an in-site path (resolved
# against NEXT_PUBLIC_SITE_URL) or an absolute URL. Place the file in /public.
NEXT_PUBLIC_DEFAULT_OG_IMAGE=/og-default.png

# Optional: Twitter/X handle for twitter:site and twitter:creator tags.
# NEXT_PUBLIC_TWITTER_HANDLE=@sagenarrative

# ── AI Writing Assistant — multi-provider ────────────────────────────────────
# The app supports five providers behind a unified interface:
#     Claude · OpenAI · Gemini · Grok · HuggingFace
# Configure ONE OR MORE of the keys below — only providers with a key set will
# appear in the Model dropdown in the dashboard editor.
#
# Server-only. Never exposed to the browser.

# Anthropic Claude — recommended (preserves prompt caching for ~10% input cost
# on cached system tokens). https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_API_KEY=sk-ant-...     # alias accepted as a fallback
# Optional model override. Default: claude-opus-4-7. Cheaper: claude-sonnet-4-6.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI. https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o            # default

# Google Gemini. https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash  # default

# xAI Grok (OpenAI-compatible). https://console.x.ai/
# GROK_API_KEY=xai-...
# GROK_MODEL=grok-3              # default

# HuggingFace (routed chat-completions). https://huggingface.co/settings/tokens
# Heads-up: small HF models won't reliably produce 1500-word coherent Markdown.
# Use a 70B+ instruction-tuned model.
# HUGGINGFACE_API_KEY=hf_...
# HUGGINGFACE_MODEL=meta-llama/Llama-3.3-70B-Instruct  # default

# ── Resend Email ──────────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The "from" address for all outgoing mail.
# Must be a verified domain in your Resend account.
EMAIL_FROM=Sage Narrative <noreply@yourdomain.com>

# Set to "false" to disable all email sending (e.g. local dev without Resend).
# If RESEND_API_KEY is empty, email is automatically disabled regardless.
EMAIL_ENABLED=true