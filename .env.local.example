# Sanity CMS Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=xb0i0wq8
NEXT_PUBLIC_SANITY_DATASET=production
MONGODB_URI=mongodb+srv://your_user:your_password@cluster.mongodb.net/?appName=Cluster0

# Optional: Sanity API token for authenticated requests (server-side only)
SANITY_API_TOKEN=your_sanity_api_token

# Optional: Sanity webhook secret for ISR revalidation
SANITY_WEBHOOK_SECRET=your_webhook_secret_here

# ── Site / SEO Configuration ──────────────────────────────────────────────────
# Absolute base URL for the deployed site. Used for canonical URLs, Open Graph
# URLs, JSON-LD `@id` values, the sitemap, and robots.txt.
# No trailing slash (one is stripped defensively, but cleaner to omit).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Display name used in titles, OG siteName, Organization schema.
NEXT_PUBLIC_SITE_NAME=Sage Narrative

# Fallback description for pages that don't provide their own.
NEXT_PUBLIC_SITE_DESCRIPTION=Thoughtful stories, tech blogs, and insights for the discerning reader.

# Default Open Graph / Twitter card image. Either an in-site path (resolved
# against NEXT_PUBLIC_SITE_URL) or an absolute URL. Place the file in /public.
NEXT_PUBLIC_DEFAULT_OG_IMAGE=/og-default.png

# Optional: Twitter/X handle for twitter:site and twitter:creator tags.
# NEXT_PUBLIC_TWITTER_HANDLE=@sagenarrative

# ── Resend Email ──────────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The "from" address for all outgoing mail.
# Must be a verified domain in your Resend account.
EMAIL_FROM=Sage Narrative <noreply@yourdomain.com>

# Set to "false" to disable all email sending (e.g. local dev without Resend).
# If RESEND_API_KEY is empty, email is automatically disabled regardless.
EMAIL_ENABLED=true